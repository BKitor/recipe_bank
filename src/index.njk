---
layout: base.njk
title: ""
---

<div class="home-header">
  <input
    id="search-input"
    type="search"
    placeholder="Search recipes…"
    autocomplete="off"
    spellcheck="false"
  >
</div>

<div class="recipe-grid" id="recipe-grid">
  {% for recipe in recipes %}
  <article class="recipe-card" data-title="{{ recipe.title | lower }}">
    {% if recipe.image %}
    <a href="/recipes/{{ recipe.id }}/" class="card-img">
      <img src="{{ recipe.image }}" alt="{{ recipe.title }}" loading="lazy">
    </a>
    {% else %}
    <a href="/recipes/{{ recipe.id }}/" class="card-img card-img--placeholder"></a>
    {% endif %}
    <div class="card-body">
      <h2><a href="/recipes/{{ recipe.id }}/">{{ recipe.title }}</a></h2>
      <div class="card-meta">
        {% if recipe.total_time_min %}
        <span>⏱ {{ recipe.total_time_min | formatTime }}</span>
        {% endif %}
        {% if recipe.servings %}
        <span>🍽 {{ recipe.servings }}</span>
        {% endif %}
      </div>
    </div>
  </article>
  {% endfor %}
</div>

<p class="no-results" id="no-results" style="display:none">No recipes match your search.</p>

<script>
(function () {
  function fuzzy(title, query) {
    if (!query) return true;
    var ti = 0;
    for (var qi = 0; qi < query.length; qi++) {
      while (ti < title.length && title[ti] !== query[qi]) ti++;
      if (ti === title.length) return false;
      ti++;
    }
    return true;
  }

  var input = document.getElementById('search-input');
  var cards = document.querySelectorAll('.recipe-card');
  var noResults = document.getElementById('no-results');

  input.addEventListener('input', function () {
    var q = input.value.toLowerCase().trim();
    var visible = 0;
    cards.forEach(function (card) {
      var show = fuzzy(card.dataset.title, q);
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    noResults.style.display = visible === 0 ? '' : 'none';
  });
})();
</script>
