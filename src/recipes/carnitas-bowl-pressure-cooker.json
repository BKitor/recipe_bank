  "instruction_groups": [
    {
      "name": "1) Pressure Cooker Carnitas (Pork Shoulder)",
      "steps": [
        "Toss pork with salt and spices.",
        "Add pork, garlic, onion, cinnamon, bay, citrus juice + halves, and stock to pressure cooker.",
        "Cook on high pressure 45–55 minutes. Natural release 15 minutes, then vent.",
        "Remove pork and shred. Discard solids.",
        "Reduce cooking liquid using sauté mode until slightly thick.",
        "Toss shredded pork with reduced liquid.",
        "Optional: Broil 5–8 minutes for crispy edges."
      ]
    },
    {
      "name": "2) Mexican Rice",
      "steps": [
        "Rinse rice thoroughly.",
        "Toast rice in oil until lightly golden.",
        "Add onion and garlic; cook briefly.",
        "Stir in tomato sauce, broth, cumin, and salt.",
        "Simmer covered 15–18 minutes. Rest 10 minutes, then fluff."
      ]
    },
    {
      "name": "3) Seasoned Beans (Black or Pinto)",
      "steps": [
        "Sauté onions over medium-high heat until soft",
        "Add garlic and spicy-pepper",
        "Add tomatoes and simmer for until slightly reduced",
        "Add beans, spices, and liquid.",
        "Simmer 5–10 minutes until slightly thickened.",
        "Adjust salt and add lime juice if desired."
      ]
    },
    {
      "name": "4) Sautéed Bell Peppers",
      "steps": [
        "Heat oil over medium-high heat.",
        "Cook peppers (and onion) 5–7 minutes until softened but slightly crisp.",
        "Add spices and salt; cook 1 minute more.",
        "Finish with lime juice."
      ]
    }
  ],
