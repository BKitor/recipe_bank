  "instruction_groups": [
    {
      "name": "1. Make the Meatballs",
      "steps": [
        "Preheat oven to 425°F (220°C) .",
        "In a large bowl mix ground turkey, egg whites, breadcrumbs, onion, garlic, soy sauce, ginger, sesame oil, salt, and pepper.",
        "Form 30–35 meatballs (~1.5 tbsp each).",
        "Place on a parchment-lined baking sheet.",
        "Bake 15–18 minutes until cooked through."
      ]
    },
    {
      "name": "2. Make the Sauce",
      "steps": [
        "Whisk together pineapple juice, rice vinegar, ketchup, soy sauce, brown sugar, water, cornstarch, and optional protein powder."
      ]
    },
    {
      "name": "3. Cook the Vegetables",
      "steps": [
        "Heat a large skillet or wok over medium-high heat.",
        "Add a small amount of oil.",
        "Stir-fry onion, bell peppers, and pineapple for 3–4 minutes until slightly softened."
      ]
    },
    {
      "name": "4. Combine",
      "steps": [
        "Add baked meatballs to the pan.",
        "Pour sauce over everything.",
        "Simmer 3–5 minutes until thickened and glossy."
      ]
    }
  ],
